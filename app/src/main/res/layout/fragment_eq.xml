<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black_true">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="32dp">

            <!-- Drag handle -->
            <View
                android:id="@+id/drag_handle"
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_drag_handle"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- Header -->
            <TextView
                android:id="@+id/label_eq"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="Equalizer"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold"
                app:layout_constraintTop_toBottomOf="@id/drag_handle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ============================================
                 BIT-PERFECT BYPASS SWITCH
                 Saat ON: EQ dinonaktifkan sepenuhnya
                 ============================================ -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/card_bitperfect"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:background="@drawable/bg_card_dark"
                android:padding="16dp"
                app:layout_constraintTop_toBottomOf="@id/label_eq"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/tv_bitperfect_label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Bit-Perfect Mode"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/switch_bitperfect"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toTopOf="@id/tv_bitperfect_desc"/>

                <TextView
                    android:id="@+id/tv_bitperfect_desc"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Nonaktifkan EQ sepenuhnya untuk output murni"
                    android:textColor="@color/text_tertiary"
                    android:textSize="12sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/switch_bitperfect"
                    app:layout_constraintTop_toBottomOf="@id/tv_bitperfect_label"/>

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_bitperfect"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/accent_primary"
                    app:trackTint="@color/black_border"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"/>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- ============================================
                 PRESET SELECTOR
                 ============================================ -->
            <TextView
                android:id="@+id/label_preset"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:text="PRESET"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                app:layout_constraintTop_toBottomOf="@id/card_bitperfect"
                app:layout_constraintStart_toStartOf="parent"/>

            <HorizontalScrollView
                android:id="@+id/preset_scroll"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:scrollbars="none"
                app:layout_constraintTop_toBottomOf="@id/label_preset"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:id="@+id/preset_chips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"/>

            </HorizontalScrollView>

            <!-- ============================================
                 PREAMP
                 ============================================ -->
            <TextView
                android:id="@+id/label_preamp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginStart="20dp"
                android:text="PREAMP"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                app:layout_constraintTop_toBottomOf="@id/preset_scroll"
                app:layout_constraintStart_toStartOf="parent"/>

            <TextView
                android:id="@+id/tv_preamp_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="20dp"
                android:text="0.0 dB"
                android:textColor="@color/accent_primary"
                android:textSize="12sp"
                app:layout_constraintTop_toBottomOf="@id/preset_scroll"
                app:layout_constraintEnd_toEndOf="parent"/>

            <SeekBar
                android:id="@+id/seekbar_preamp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:max="240"
                android:progress="120"
                android:progressTint="@color/accent_primary"
                android:thumb="@drawable/seekbar_thumb"
                android:progressBackgroundTint="@color/black_border"
                app:layout_constraintTop_toBottomOf="@id/label_preamp"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ============================================
                 10 BAND EQ
                 Setiap band: label freq | seekbar vertikal | nilai dB
                 Layout: horizontal LinearLayout berisi 10 kolom
                 ============================================ -->
            <TextView
                android:id="@+id/label_bands"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:text="BANDS"
                android:textColor="@color/text_tertiary"
                android:textSize="11sp"
                android:letterSpacing="0.1"
                android:textAllCaps="true"
                app:layout_constraintTop_toBottomOf="@id/seekbar_preamp"
                app:layout_constraintStart_toStartOf="parent"/>

            <!-- Container 10 band — diisi programatik di Fragment -->
            <LinearLayout
                android:id="@+id/eq_bands_container"
                android:layout_width="0dp"
                android:layout_height="220dp"
                android:layout_marginTop="12dp"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="8dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/label_bands"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <!-- ============================================
                 TOMBOL RESET + SAVE
                 ============================================ -->
            <LinearLayout
                android:id="@+id/eq_action_buttons"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/eq_bands_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_reset"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Reset"
                    android:textColor="@color/text_secondary"
                    app:strokeColor="@color/black_border"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save_preset"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Simpan Preset"
                    android:textColor="@color/black_true"
                    app:backgroundTint="@color/accent_primary"/>

            </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
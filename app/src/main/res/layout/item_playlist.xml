<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:background="?attr/selectableItemBackground">

    <!-- Cover art playlist -->
    <androidx.cardview.widget.CardView
        android:id="@+id/card_playlist_art"
        android:layout_width="52dp"
        android:layout_height="52dp"
        app:cardCornerRadius="6dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="@color/black_elevated"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/item_playlist_art"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_playlist"/>

    </androidx.cardview.widget.CardView>

    <!-- Nama playlist -->
    <TextView
        android:id="@+id/item_playlist_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="8dp"
        android:ellipsize="end"
        android:singleLine="true"
        android:textColor="@color/text_primary"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintStart_toEndOf="@id/card_playlist_art"
        app:layout_constraintEnd_toStartOf="@id/btn_playlist_menu"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/item_playlist_count"/>

    <!-- Jumlah lagu -->
    <TextView
        android:id="@+id/item_playlist_count"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="2dp"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        app:layout_constraintStart_toEndOf="@id/card_playlist_art"
        app:layout_constraintEnd_toStartOf="@id/btn_playlist_menu"
        app:layout_constraintTop_toBottomOf="@id/item_playlist_name"
        app:layout_constraintBottom_toBottomOf="parent"/>

    <!-- Menu -->
    <ImageButton
        android:id="@+id/btn_playlist_menu"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_more_vert"
        android:tint="@color/text_tertiary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
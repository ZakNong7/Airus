<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.Airus" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- AMOLED black background -->
        <item name="android:windowBackground">@color/black_true</item>
        <item name="android:colorBackground">@color/black_true</item>
        <item name="colorSurface">@color/black_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Accent amber -->
        <item name="colorPrimary">@color/accent_primary</item>
        <item name="colorPrimaryVariant">@color/accent_secondary</item>
        <item name="colorOnPrimary">@color/black_true</item>
        <item name="colorSecondary">@color/accent_primary</item>

        <!-- Status bar transparent -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@color/black_true</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Fullscreen immersive -->
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="28">shortEdges</item>
    </style>

    <style name="ShapeAppearance.Airus.RoundedArt" parent="">
        <item name="cornerSize">12dp</item>
    </style>
</resources>
